/*
https://vb-consulting.github.io/npgsqlrest/config/
*/
{
  "EnvironmentName": "Development",
  "StartupMessage": "NpgsqlRest Version {2}, Development Configuration, Started in {0}, listening on http://127.0.0.1:5000",

  "Config": {
    "ExposeAsEndpoint": "/config"
  },

  "Log": {
    "RetainedFileCountLimit": 3,
    "PostgresMinimumLevel": "Information"
  },

  "NpgsqlRest": {
    "LogEndpointCreatedInfo": true,
    "LogAnnotationSetInfo": true,
    "LogConnectionNoticeEvents": true,
    "LogCommands": true,
    "LogCommandParameters": true,

    "RefreshOptions": {
      "Enabled": true,
      "Path": "/npgsqlrest/refresh",
      "Method": "GET"
    },

    "HttpFileOptions": {
      "Enabled": true,
      "Option": "File",
      "Name": "todo",
      "NamePattern": "./http/{0}_{1}",
      "CommentHeader": "Simple",
      "CommentHeaderIncludeComments": true,
      "FileMode": "Schema",
      "FileOverwrite": true
    },

    "ClientCodeGen": {
      "Enabled": true,
      "FilePath": "./app/api/{0}Api.ts",
      "FileOverwrite": true,
      "IncludeHost": true,
      "CustomHost": null,
      "CommentHeader": "Simple",
      "CommentHeaderIncludeComments": true,
      "BySchema": true,
      "IncludeStatusCode": true,
      "CreateSeparateTypeFile": true,
      "ImportBaseUrlFrom": "./_urls",
      "ImportParseQueryFrom": "./_urls",
      "IncludeParseUrlParam": false,
      "IncludeParseRequestParam": false,
      "HeaderLines": [
        "// autogenerated at {0}",
        ""
      ],
      "SkipRoutineNames": [],
      "SkipFunctionNames": [],
      "SkipPaths": [],
      "SkipSchemas": ["public", "_"],
      "DefaultJsonType": "string",
      "UseRoutineNameInsteadOfEndpoint": false,
      "ExportUrls": true,
      "SkipTypes": false,
      "UniqueModels": false,
      "ExportEventSources": true,
      "CustomImports": [],
      "CustomHeaders": {}
    }
  }
}